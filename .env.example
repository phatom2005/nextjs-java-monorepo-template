# --- DATABASE CONFIGURATION ---
# Mật khẩu cho tài khoản 'admin' của PostgreSQL (Dùng trong Docker Compose)
DB_PASSWORD=your_secure_password_here

# --- API & FRONTEND CONFIGURATION ---
# URL của Backend API để Next.js có thể gọi tới (Mặc định là http://localhost:5000)
NEXT_PUBLIC_API_URL=http://localhost:5000

# --- CI/CD SECRETS (CHỈ DÙNG ĐỂ THAM KHẢO CHO GITHUB SECRETS) ---
# Các biến này không nên đặt trong file .env thật ở máy local
# SNYK_TOKEN=your_snyk_api_token
# DOCKERHUB_USERNAME=your_dockerhub_username
# DOCKERHUB_TOKEN=your_dockerhub_access_token